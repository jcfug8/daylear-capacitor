# API (apps/api)
DATABASE_URL=postgresql://daylear:daylear@localhost:5433/daylear
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
API_PORT=3000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Frontends
VITE_API_URL=http://localhost:3000
VITE_APP_URL=http://localhost:5173

# LAN / device testing: pnpm dev:network — open the printed *app* URL (port 5173).
# Auth/tRPC are proxied through Vite; do not browse the API port directly.
#
# iOS Simulator / Android emulator (bundled app): VITE_API_URL=http://localhost:3000
# and run the API (pnpm dev). CORS allows capacitor://localhost automatically.
# Android emulator: use `pnpm cap:android` (sets hostname 10.0.2.2 + http scheme) so auth
# cookies are same-site with http://10.0.2.2:3000. Plain cap:sync leaves https://localhost
# and SameSite=Lax cookies from the API are blocked. cap:sync also enables Android cleartext
# HTTP for the dev API (ERR_CLEARTEXT_NOT_PERMITTED without it).
# Physical Android: VITE_API_URL=http://YOUR_LAN_IP:3000 — cap sync aligns WebView hostname.
# Re-run pnpm cap:sync after changing VITE_API_URL.
# Physical Android device: use your Mac LAN IP, e.g. VITE_API_URL=http://192.168.1.10:3000
